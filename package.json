{
    "name": "hamadeh-io",
    "version": "1.2.2",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "dev:fresh": "bun run clean:next && bun run dev",
        "build": "next build",
        "start": "next start",
        "check": "oxlint --react-plugin --jsx-a11y-plugin --nextjs-plugin .",
        "check:fix": "oxlint --fix --react-plugin --jsx-a11y-plugin --nextjs-plugin . && oxfmt --write .",
        "check:staged": "bun scripts/check-staged.ts",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "type-check": "tsgo --noEmit",
        "type-check:tsc": "tsc --noEmit",
        "test": "bun test",
        "test:coverage": "bun test --coverage",
        "clean": "bun scripts/clean.ts",
        "clean:next": "bun scripts/clean-next.ts",
        "healthcheck": "bun run format:check && bun run type-check && bun run check && bun test",
        "new:problem": "bun scripts/new-problem.ts",
        "publish:problem": "bun scripts/publish-problem.ts",
        "prepare": "husky"
    },
    "dependencies": {
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@tailwindcss/typography": "^0.5.19",
        "clsx": "^2.1.1",
        "gray-matter": "^4.0.3",
        "next": "^16.2.6",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-icons": "^5.6.0",
        "react-markdown": "^10.1.0",
        "rehype-pretty-code": "^0.14.3",
        "remark-gfm": "^4.0.1",
        "shiki": "^4.0.2",
        "tailwind-merge": "^3.6.0",
        "valibot": "^1.4.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.0",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.7.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript/native-preview": "^7.0.0-dev.20260517.1",
        "husky": "^9.1.7",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.64.0",
        "postcss": "^8.5.14",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3"
    },
    "overrides": {
        "postcss": "8.5.14"
    },
    "engines": {
        "bun": ">=1.3.0",
        "node": ">=24.0.0"
    }
}
