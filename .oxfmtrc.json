{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "useTabs": false,
    "tabWidth": 4,
    "printWidth": 80,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "quoteProps": "as-needed",
    "trailingComma": "es5",
    "semi": true,
    "arrowParens": "always",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "ignorePatterns": []
}
